# .env.example 配置示例

# Mercado Libre API 凭证配置
MERCADO_LIBRE_CLIENT_ID=你的_CLIENT_ID
MERCADO_LIBRE_CLIENT_SECRET=你的_CLIENT_SECRET

# 日志配置
LOG_LEVEL=info
LOG_PATH=/var/log/ecommerce-scraper.log

# 数据输出路径
OUTPUT_PATH=/path/to/output

# 定时任务间隔（以秒为单位）
TIMER_INTERVAL=300

# 搜索关键词
SEARCH_KEYWORDS="手机, 电脑, 电子产品"

# 最大结果数
MAX_RESULTS=50

# API 超时时间（以秒为单位）
API_TIMEOUT=30

# 调度器开关
SCHEDULER_ENABLED=true

# 站点 ID
SITE_ID=MLA

# 跨境识别
CROSS_BORDER=true
